# Ambiente da aplicação
NODE_ENV=development
PORT=3000

# Banco de dados (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=ovgs
DATABASE_PASSWORD=ovgs
DATABASE_NAME=ovgs

# Autenticação (JWT) — troque JWT_SECRET por um segredo forte em produção
JWT_SECRET=dev-insecure-secret-change-me!!
JWT_EXPIRES_IN=1d

# Usuário administrador criado pelo seed (npm run seed)
ADMIN_EMAIL=admin@ovgs.local
ADMIN_PASSWORD=admin12345
